# PostgreSQL connection string used by Prisma.
# Local (brew/local postgres):   postgresql://USER@localhost:5432/mini_saas
# Docker Compose (see compose):  postgresql://postgres:postgres@db:5432/mini_saas
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/mini_saas"

# Secret used to sign session JWTs. Generate with: openssl rand -base64 32
JWT_SECRET="replace-me-with-a-long-random-string"
